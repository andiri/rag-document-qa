# 기존 RAG 웹앱용 (브라우저 OpenAI)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ── 오늘의 한경 브리핑 (scripts/daily-brief) ──
# 로컬 실행 시 사용. GitHub Actions 에서는 repo Secrets 로 설정.

# 요약 LLM: Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# 이메일 발송 + 지면 PDF 자동수집(IMAP). 2단계 인증 후 '앱 비밀번호' 발급 필요.
# https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
MAIL_TO=you@gmail.com

# 경로 C1 자동화(선택): 받은편지함의 지면 PDF 첨부를 자동 요약. 1로 켜면 PDF 우선, 없으면 RSS.
PDF_FROM_EMAIL=0
# PDF_EMAIL_FROM=hankyung.com         # 보낸사람 필터(선택)
# PDF_EMAIL_SUBJECT=지면               # 제목 포함 필터(선택)
# PDF_EMAIL_SINCE_HOURS=18            # 최근 N시간 이내 메일만(기본 18)
